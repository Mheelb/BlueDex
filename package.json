    "@tanstack/pacer": "^0.21.1",
    "@tanstack/vue-form": "^1.33.1",
    "@tanstack/vue-query": "^5.101.2",
    "@tanstack/vue-table": "^8.21.3",
    "@tanstack/vue-virtual": "^3.13.31",
    "@unhead/vue": "^3.1.8",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
